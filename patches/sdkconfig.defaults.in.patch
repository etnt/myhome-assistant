--- a/src/platforms/esp32/sdkconfig.defaults.in
+++ b/src/platforms/esp32/sdkconfig.defaults.in
@@ -4,3 +4,12 @@
 CONFIG_LWIP_IPV6=n
 CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="@AVM_PARTITION_TABLE_FILENAME@"
 CONFIG_APP_REPRODUCIBLE_BUILD=y
+
+# BLE disabled — offloaded to external XIAO nRF52840 via I2C
+CONFIG_BT_ENABLED=n
+
+# PSRAM (8 MB octal SPI on ESP32-S3-WROOM)
+CONFIG_SPIRAM=y
+CONFIG_SPIRAM_MODE_OCT=y
+CONFIG_SPIRAM_SPEED_80M=y
+CONFIG_SPIRAM_USE_MALLOC=y
